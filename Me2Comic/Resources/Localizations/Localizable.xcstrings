    "BatchSizeDesc" : {
      "comment" : "每批图像数（张）：",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Distributes the number of images each thread processes based on the CPU count. Proper settings can improve efficiency; range: 1–1000 (disabled in Auto mode)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "CPU 数に応じて各スレッドが処理する画像数を割り当てます。適切に設定すると処理効率が向上します。範囲：1〜1000（自動モードでは無効）。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "根据 CPU 个数分配每个线程处理的图像数量，合理设置可提升处理效率；范围 1–1000（自动模式下无效）"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "根據 CPU 個數分配每個執行緒處理的影像數量，合理設定可提升處理效率；範圍 1–1000（自動模式下無效）"
          }
        }
      }
    },
